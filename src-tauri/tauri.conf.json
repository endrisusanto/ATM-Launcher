{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATM Bersama",
  "version": "0.1.0",
  "identifier": "com.atm.batch.launcher",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ATM Bersama by endri.s@samsung.com",
        "width": 1720,
        "height": 1080,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/atm-batch-launcher/*": "atm-batch-launcher/"
    }
  }
}